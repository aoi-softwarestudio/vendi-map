# SocialIntent API Environment Configuration Template
# Create a copy of this file named ".env" and fill in your actual credentials.

# 1. Stripe API Keys (Get these from developers dashboard in Stripe)
# For local testing, use "sk_test_..." and for production use "sk_live_..."
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe Webhook Signing Secret (Get this by registering a Webhook endpoint)
# Webhook Endpoint: https://your-backend-domain.com/webhook/stripe
# For local testing, run "stripe listen --forward-to localhost:10000/webhook/stripe" and copy the whsec key.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# 2. Gemini API Key (For the server-side proxy rate-limiting)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Optional: Flask server port (default is 10000)
PORT=10000
